# adipa-market-intel — environment variables
# Copy to .env before starting: cp .env.example .env

# ── Postgres ──────────────────────────────────
POSTGRES_USER=adipa
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=market_intel

# ── Prefect UI ────────────────────────────────
# Local deployment : localhost
# VM deployment    : set to the server's public IP
PUBLIC_HOST=localhost
